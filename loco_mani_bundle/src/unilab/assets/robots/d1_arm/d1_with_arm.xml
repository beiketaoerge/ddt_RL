<mujoco model="d1">
  <compiler angle="radian" autolimits="true"/>

  <option iterations="1" ls_iterations="5" timestep="0.004" integrator="Euler">
    <flag eulerdamp="disable"/>
  </option>

  <custom>
    <numeric data="30" name="max_contact_points"/>
    <numeric data="12" name="max_geom_pairs"/>
  </custom>

  <default>
    <default class="obj_collision">
      <geom group="3" contype="1" conaffinity="1"/>
    </default>

    <default class="airbot_play">
      <joint axis="0 0 1" armature="0.01" damping="1" frictionloss="5"/>
      <position inheritrange="1" kp="35" forcerange="-18 18"/>
      <default class="joint1">
        <joint range="-3.1416 2.0944" actuatorfrcrange="-24 24" damping="0.2" frictionloss="1"/>
      </default>
      <default class="joint2">
        <joint range="-2.9671 0.17453" actuatorfrcrange="-24 24" damping="0.2" frictionloss="1"/>
      </default>
      <default class="joint3">
        <joint range="-0.087266 3.1416" actuatorfrcrange="-24 24" damping="0.2" frictionloss="1"/>
      </default>
      <default class="joint4">
        <joint range="-3.0107 3.0107" actuatorfrcrange="-8 8" damping="0.1" frictionloss="0.5"/>
        <position forcerange="-8 8"/>
      </default>
      <default class="joint5">
        <joint range="-1.7628 1.7628" actuatorfrcrange="-8 8" damping="0.1" frictionloss="0.5"/>
        <position forcerange="-8 8"/>
      </default>
      <default class="joint6">
        <joint range="-3.0107 3.0107" actuatorfrcrange="-8 8" damping="0.1" frictionloss="0.5"/>
        <position forcerange="-8 8"/>
      </default>
    </default>

    <default class="d1">
      <geom friction="0.6" margin="0.001" condim="1"/>
      <joint damping="0.5" armature="0.01" frictionloss="0.2"/>
    </default>
    <default class="d1_hip">
      <joint axis="0 0 1" range="-0.785398 0.785398"/>
    </default>
    <default class="d1_thigh">
      <joint axis="0 0 1" range="-1.8326 3.40339"/>
    </default>
    <default class="d1_calf">
      <joint axis="0 0 1" range="-2.775 -0.855"/>
    </default>
    <default class="d1_wheel">
      <joint axis="0 0 1" range="-1000000 1000000"/>
    </default>
  </default>

