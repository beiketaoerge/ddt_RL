  <actuator>
    <!-- Actuator order matches qpos order (Isaac Lab D1 convention):
         per-leg [hip_pos, thigh_pos, calf_pos, wheel_vel] x 4, then arm x 6.
         Wheel velocity control: force = Kv*(ctrl - vel), via gainprm[0]=Kv, biasprm[2]=-Kv.
         Leg/wheel gains are baked in XML; arm gains are set at runtime.
         Wheel actuators do NOT use biastype="affine" to prevent the backend's
         position-actuator gain override from corrupting their velocity-control formula. -->

    <!-- FL leg -->
    <general name="FL_hip" joint="FL_hip_joint" biastype="affine" gainprm="60 0 0" biasprm="0 -60 -1.5" forcerange="-80 80" ctrlrange="-0.785 0.785"/>
    <general name="FL_thigh" joint="FL_thigh_joint" biastype="affine" gainprm="60 0 0" biasprm="0 -60 -1.5" forcerange="-80 80" ctrlrange="-1.83 3.4"/>
    <general name="FL_calf" joint="FL_calf_joint" biastype="affine" gainprm="60 0 0" biasprm="0 -60 -1.5" forcerange="-80 80" ctrlrange="-2.775 -0.855"/>
    <velocity name="FL_wheel" joint="FL_foot_joint" kv="0.5" forcerange="-12 12" ctrlrange="-30 30"/>
    <!-- FR leg -->
    <general name="FR_hip" joint="FR_hip_joint" biastype="affine" gainprm="60 0 0" biasprm="0 -60 -1.5" forcerange="-80 80" ctrlrange="-0.785 0.785"/>
    <general name="FR_thigh" joint="FR_thigh_joint" biastype="affine" gainprm="60 0 0" biasprm="0 -60 -1.5" forcerange="-80 80" ctrlrange="-1.83 3.4"/>
    <general name="FR_calf" joint="FR_calf_joint" biastype="affine" gainprm="60 0 0" biasprm="0 -60 -1.5" forcerange="-80 80" ctrlrange="-2.775 -0.855"/>
    <velocity name="FR_wheel" joint="FR_foot_joint" kv="0.5" forcerange="-12 12" ctrlrange="-30 30"/>
    <!-- RL leg -->
    <general name="RL_hip" joint="RL_hip_joint" biastype="affine" gainprm="60 0 0" biasprm="0 -60 -1.5" forcerange="-80 80" ctrlrange="-0.785 0.785"/>
    <general name="RL_thigh" joint="RL_thigh_joint" biastype="affine" gainprm="60 0 0" biasprm="0 -60 -1.5" forcerange="-80 80" ctrlrange="-1.83 3.4"/>
    <general name="RL_calf" joint="RL_calf_joint" biastype="affine" gainprm="60 0 0" biasprm="0 -60 -1.5" forcerange="-80 80" ctrlrange="-2.775 -0.855"/>
    <velocity name="RL_wheel" joint="RL_foot_joint" kv="0.5" forcerange="-12 12" ctrlrange="-30 30"/>
    <!-- RR leg -->
    <general name="RR_hip" joint="RR_hip_joint" biastype="affine" gainprm="60 0 0" biasprm="0 -60 -1.5" forcerange="-80 80" ctrlrange="-0.785 0.785"/>
    <general name="RR_thigh" joint="RR_thigh_joint" biastype="affine" gainprm="60 0 0" biasprm="0 -60 -1.5" forcerange="-80 80" ctrlrange="-1.83 3.4"/>
    <general name="RR_calf" joint="RR_calf_joint" biastype="affine" gainprm="60 0 0" biasprm="0 -60 -1.5" forcerange="-80 80" ctrlrange="-2.775 -0.855"/>
    <velocity name="RR_wheel" joint="RR_foot_joint" kv="0.5" forcerange="-12 12" ctrlrange="-30 30"/>

    <!-- Arm position actuators: 6 total (Kp/Kd set at runtime) -->
    <position joint="joint1" class="joint1" forcerange="-24 24" forcelimited="true" ctrllimited="true"/>
    <position joint="joint2" class="joint2" forcerange="-24 24" forcelimited="true" ctrllimited="true"/>
    <position joint="joint3" class="joint3" forcerange="-24 24" forcelimited="true" ctrllimited="true"/>
    <position joint="joint4" class="joint4" forcerange="-8 8" forcelimited="true" ctrllimited="true"/>
    <position joint="joint5" class="joint5" forcerange="-8 8" forcelimited="true" ctrllimited="true"/>
    <position joint="joint6" class="joint6" forcerange="-8 8" forcelimited="true" ctrllimited="true"/>
  </actuator>

  <sensor>
    <!-- D1 leg joint position sensors: 16 total (hip, thigh, calf, foot per leg) -->
    <jointpos joint="FL_hip_joint" name="FL_hip_pos"/>
    <jointpos joint="FL_thigh_joint" name="FL_thigh_pos"/>
    <jointpos joint="FL_calf_joint" name="FL_calf_pos"/>
